    "problemStatementLatex": "4. \\text{ Evaluate } \\int_{0}^{2} (2x + 1) \\, dx",
    "solutionSteps": [
      "\\int_{0}^{2} (2x + 1) \\, dx = \\int_{0}^{2} 2x \\, dx + \\int_{0}^{2} 1 \\, dx",
      "= \\left[ \\frac{2x^2}{2} \\right]_{0}^{2} + [x]_{0}^{2}",
      "= [x^2]_{0}^{2} + [x]_{0}^{2}",
      "= (2^2 - 0^2) + (2 - 0)",
      "= 4 + 2",
      "= 6"
